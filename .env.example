# Copy to .env and adjust for your local setup.
# Default: SQLite file at prisma/dev.db (created by `npm run db:push`).
DATABASE_URL="file:./dev.db"

# To use Postgres instead:
# 1. Change `provider = "postgresql"` in prisma/schema.prisma.
# 2. Re-enable enums (see the original schema in git history) or keep string fields.
# 3. Set DATABASE_URL like:
# DATABASE_URL="postgresql://vessel:vessel@localhost:5433/vessel_finance?schema=public"

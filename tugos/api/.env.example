# TugOS API — environment (copy to .env; .env is gitignored)

# Tenant-scoped connection: connect as the NON-bypass app role tug_api.
# Supabase: Project Settings -> Database -> Connection string (Postgres),
# then swap the user to tug_api and use its password. SSL is required.
# Format: postgresql://tug_api:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://tug_api:CHANGE_ME@db.naxqxajzlmisqdnfvhzm.supabase.co:5432/postgres?sslmode=require

# Secret for signing 15-minute access tokens. Use a long random value.
JWT_SECRET=CHANGE_ME_LONG_RANDOM

# HTTP port
PORT=3001

# Comma-separated CORS allow-list (e.g. https://app.tugos.example,https://admin.tugos.example).
# Leave unset in dev to reflect the request origin.
CORS_ORIGINS=

# Set to 1 to skip TLS cert verification for the DB connection (dev only).
PGSSL_NO_VERIFY=0
